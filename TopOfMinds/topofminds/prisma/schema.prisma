generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Consultant {
  id                String   @id @default(uuid())
  firstName         String
  lastName          String
  email             String   @unique
  phone             String?
  title             String?
  team              String?  // Steam, Accelerate, Drive, etc.
  skills            String?  // JSON array stored as string for SQLite
  status            String   @default("AVAILABLE") // AVAILABLE, ON_CONTRACT, ON_LEAVE
  avatarUrl         String?
  hourlyRate        Float?
  bio               String?
  education         String?  // JSON array
  experience        String?  // JSON array (work history / uppdragshistorik)
  interests         String?
  developmentGoals  String?
  linkedin          String?
  cvUrl             String?
  certifications    String?  // JSON array [{name, year}]
  languages         String?  // JSON array [{language, level}] level: native/fluent/basic
  employmentHistory String?  // JSON array [{company, period, role}]
  industryExpertise String?  // JSON array of industry names
  nationality       String?
  address           String?
  wantsNewAssignment Boolean @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contracts         Contract[]
  user              User?
  matches           AssignmentMatch[]
  applications      Application[]
}

// ==================== AUTH ====================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?  // Optional — Google OAuth users don't have passwords
  googleId      String?  @unique // Google 'sub' claim
  avatarUrl     String?  // Profile picture from Google
  role          String   @default("CONSULTANT") // SUPERADMIN, ADMIN, CONSULTANT
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Optional link for CONSULTANT role → their consultant profile
  consultantId  String?  @unique
  consultant    Consultant? @relation(fields: [consultantId], references: [id], onDelete: SetNull)
}

model Client {
  id            String   @id @default(uuid())
  name          String
  orgNumber     String?
  contactPerson String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contracts     Contract[]
}

model Contract {
  id                String   @id @default(uuid())
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime
  rate              Float?
  rateType          String   @default("HOURLY") // HOURLY, MONTHLY, FIXED
  estimatedHours    Int?
  status            String   @default("ACTIVE") // DRAFT, ACTIVE, EXPIRING_SOON, EXPIRED, RENEWED, TERMINATED
  renewalNoticeDays Int      @default(30)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  consultantId String
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  notifications Notification[]
}

model Notification {
  id          String   @id @default(uuid())
  type        String   @default("RENEWAL_WARNING") // RENEWAL_WARNING, EXPIRATION, CUSTOM
  message     String
  isRead      Boolean  @default(false)
  emailSent   Boolean  @default(false)
  triggerDate DateTime
  createdAt   DateTime @default(now())

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// ==================== KANBAN ====================

model KanbanIssue {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String   @default("NY") // NY, PRIORITERAD, PAGAR_UTVECKLING, ANTIGRAVITY_VERIFIERAR, REDO_FOR_VERIFIERING, KLAR
  order       Int      @default(0)
  creatorName String   @default("Admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      KanbanImage[]
  comments    KanbanComment[]
  agentTasks  AgentTask[]
}

model KanbanComment {
  id        String   @id @default(uuid())
  body      String
  authorName String  @default("Admin")
  createdAt DateTime @default(now())

  issueId   String
  issue     KanbanIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  images    KanbanCommentImage[]
}

model KanbanImage {
  id      String  @id @default(uuid())
  url     String
  caption String?
  order   Int     @default(0)

  issueId String
  issue   KanbanIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model KanbanCommentImage {
  id      String  @id @default(uuid())
  url     String
  caption String?
  order   Int     @default(0)

  commentId String
  comment   KanbanComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

// ==================== AGENT ====================

model AgentSession {
  id             String   @id @default(uuid())
  title          String
  claudeSessionId String?
  pinned         Boolean  @default(false)
  createdBy      String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks          AgentTask[]
}

model AgentTask {
  id        String   @id @default(uuid())
  prompt    String
  status    String   @default("PENDING") // PENDING, RUNNING, DONE, FAILED, STOPPED
  model     String?
  error     String?
  response  String?
  createdBy String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId     String
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  kanbanIssueId String?
  kanbanIssue   KanbanIssue? @relation(fields: [kanbanIssueId], references: [id], onDelete: SetNull)

  logs          AgentLog[]
}

model AgentLog {
  id        String   @id @default(uuid())
  message   String
  createdAt DateTime @default(now())

  taskId    String
  task      AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ==================== ASSIGNMENTS & MATCHING ====================

model Assignment {
  id                String   @id @default(uuid())
  title             String
  description       String   // full extracted description
  clientName        String?  // end customer (e.g. "ICA Sverige")
  brokerName        String?  // broker/agency who sent the request
  brokerEmail       String?
  location          String?  // on-site / remote / hybrid / city
  startDate         DateTime?
  endDate           DateTime?
  applicationDeadline DateTime?
  estimatedHours    Int?
  rateMin           Float?
  rateMax           Float?
  rateType          String?  // HOURLY | MONTHLY | FIXED
  requiredSkills    String?  // JSON array of strings
  preferredSkills   String?  // JSON array of strings
  languageRequirements String? // JSON array
  industry          String?
  seniority         String?  // JUNIOR | MID | SENIOR
  category          String?  // Backend, Frontend, Fullstack, DevOps/Cloud, Data/BI, etc.
  status            String   @default("NEW") // NEW | MATCHED | SENT | CLOSED | ARCHIVED
  sourceType        String   @default("EMAIL") // EMAIL | MANUAL | API
  sourceRaw         String?  // original email body / raw input
  sourceSubject     String?
  extractionConfidence Float? // 0..1 from AI extraction
  extractionNotes   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  matches       AssignmentMatch[]
  applications  Application[]

  @@index([status, createdAt])
  @@index([applicationDeadline])
}

model AssignmentMatch {
  id              String   @id @default(uuid())
  assignmentId    String
  consultantId    String
  score           Int      // 0-100
  matchedSkills   String?  // JSON array
  missingSkills   String?  // JSON array
  summary         String?  // short human-readable match explanation
  strengths       String?  // JSON array of bullet points
  concerns        String?  // JSON array of bullet points
  recommendation  String?  // STRONG_MATCH | GOOD_MATCH | POSSIBLE | POOR
  modelId         String?  // which AI model produced this
  jobId           String?  // links to AIUsageLog/AIShadowResult
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  consultant      Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, consultantId])
  @@index([assignmentId, score])
  @@index([consultantId, score])
}

model Application {
  id              String   @id @default(uuid())
  assignmentId    String
  consultantId    String
  status          String   @default("INTERESTED") // INTERESTED | DRAFT_CV | APPLIED | REJECTED | WITHDRAWN | WON
  tailoredCv      String?  // generated CV text
  coverNote       String?
  appliedAt       DateTime?
  createdByUserId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  consultant      Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, consultantId])
  @@index([consultantId, status])
}

// ==================== BROKER SOURCES ====================

model BrokerSource {
  id                String    @id @default(uuid())
  name              String    // "Cinode", "E-Work", "Brights", etc.
  type              String    // PORTAL | EMAIL | API
  url               String?   // portal login URL
  domain            String?   // email domain filter, e.g. "cinode.com"
  username          String?   // login email/user (shown in UI)
  credentialsCipher String?   // AES-256-GCM encrypted password/secret
  config            String?   // JSON: platform-specific config (selectors, paths, etc.)
  enabled           Boolean   @default(true)
  lastCheckedAt     DateTime?
  lastResult        String?   // SUCCESS | ERROR | description
  assignmentsFound  Int       @default(0) // total assignments found from this source
  checkIntervalMin  Int       @default(30)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ==================== AI INFRASTRUCTURE ====================

model ModelRegistry {
  id                   String   @id @default(uuid())
  modelId              String   @unique // e.g. "gemini-3-flash", "claude-sonnet-4-6"
  provider             String   // GOOGLE | ANTHROPIC | DEEPSEEK | ...
  displayName          String
  category             String   @default("BALANCED") // FAST | BALANCED | FRONTIER
  inputPricePerMTok    Float    // USD per million input tokens
  outputPricePerMTok   Float    // USD per million output tokens
  contextWindow        Int      @default(200000)
  enabled              Boolean  @default(true)
  capabilities         String?  // JSON: {vision, tools, thinking, ...}
  notes                String?
  discoveredAt         DateTime @default(now())
  lastVerifiedAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  championFor          AISetting[] @relation("ChampionModel")
  challengerFor        AISetting[] @relation("ChallengerModel")
  usageLogs            AIUsageLog[]
}

model AISetting {
  id                  String   @id @default(uuid())
  pipelineStep        String   @unique // EMAIL_EXTRACTION | MATCHING | CV_GENERATION | CV_PARSING
  championModelId     String
  challengerModelId   String?
  shadowSampleRate    Int      @default(0)   // 0-100; pct of champion calls shadowed
  temperature         Float?
  maxTokens           Int?
  systemPrompt        String?
  updatedBy           String?  // userId
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  champion            ModelRegistry  @relation("ChampionModel", fields: [championModelId], references: [modelId], onDelete: Restrict)
  challenger          ModelRegistry? @relation("ChallengerModel", fields: [challengerModelId], references: [modelId], onDelete: SetNull)
}

model AIUsageLog {
  id                String   @id @default(uuid())
  createdAt         DateTime @default(now())
  pipelineStep      String
  modelId           String
  role              String   @default("CHAMPION") // CHAMPION | CHALLENGER
  jobId             String?  // groups champion + challenger for same input
  assignmentId      String?
  consultantId      String?
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  estimatedCostUSD  Float    @default(0)
  latencyMs         Int      @default(0)
  status            String   @default("SUCCESS") // SUCCESS | ERROR
  errorMessage      String?
  userId            String?

  model             ModelRegistry @relation(fields: [modelId], references: [modelId], onDelete: Restrict)

  @@index([createdAt])
  @@index([pipelineStep, createdAt])
  @@index([jobId])
}

model AIShadowResult {
  id              String   @id @default(uuid())
  jobId           String
  pipelineStep    String
  modelId         String
  role            String   // CHAMPION | CHALLENGER
  output          String   // raw model output (JSON-encoded when structured)
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  latencyMs       Int      @default(0)
  createdAt       DateTime @default(now())

  comparisons     AIComparison[]

  @@index([jobId])
}

model AIComparison {
  id              String   @id @default(uuid())
  shadowResultId  String
  reviewerId      String   // user id
  preference      String   // A_BETTER | B_BETTER | TIE
  notes           String?
  createdAt       DateTime @default(now())

  shadowResult    AIShadowResult @relation(fields: [shadowResultId], references: [id], onDelete: Cascade)
}
