generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth) ────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  kanbanIssues   KanbanIssue[]    @relation("KanbanCreator")
  kanbanComments KanbanComment[]  @relation("KanbanCommentAuthor")
  agentSessions  AgentSession[]
  agentTasks     AgentTask[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── AGENT TASKS ────────────────────────────────────

enum AgentTaskStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  STOPPED
}

model AgentSession {
  id              String   @id @default(cuid())
  title           String
  claudeSessionId String?
  pinned          Boolean  @default(false)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator User        @relation(fields: [createdBy], references: [id])
  tasks   AgentTask[]

  @@index([createdBy, updatedAt])
  @@index([pinned, updatedAt])
  @@map("agent_sessions")
}

model AgentTask {
  id             String          @id @default(cuid())
  prompt         String
  status         AgentTaskStatus @default(PENDING)
  error          String?
  response       String?
  model          String?
  sessionId      String?
  kanbanIssueId  String?
  createdBy      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  creator      User          @relation(fields: [createdBy], references: [id])
  session      AgentSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kanbanIssue  KanbanIssue?  @relation(fields: [kanbanIssueId], references: [id])
  logs         AgentTaskLog[]

  @@index([status])
  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([kanbanIssueId])
  @@map("agent_tasks")
}

model AgentTaskLog {
  id        String   @id @default(cuid())
  taskId    String
  message   String
  createdAt DateTime @default(now())

  task AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("agent_task_logs")
}

// ─── KANBAN / ISSUE TRACKER ─────────────────────────

enum KanbanStatus {
  NY
  PRIORITERAD
  PAGAR_UTVECKLING
  ANTIGRAVITY_VERIFIERAR
  REDO_FOR_VERIFIERING
  KLAR
}

model KanbanIssue {
  id          String       @id @default(cuid())
  title       String
  description String       @db.Text
  status      KanbanStatus @default(NY)
  order       Int          @default(0)
  creatorId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creator     User              @relation("KanbanCreator", fields: [creatorId], references: [id])
  comments    KanbanComment[]
  images      KanbanIssueImage[]
  agentTasks  AgentTask[]

  @@index([status, order])
  @@index([creatorId])
  @@map("kanban_issues")
}

model KanbanComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  issue     KanbanIssue          @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author    User                 @relation("KanbanCommentAuthor", fields: [authorId], references: [id])
  images    KanbanCommentImage[]

  @@index([issueId, createdAt])
  @@map("kanban_comments")
}

model KanbanIssueImage {
  id        String   @id @default(cuid())
  issueId   String
  url       String   @db.Text
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  issue     KanbanIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@map("kanban_issue_images")
}

model KanbanCommentImage {
  id        String   @id @default(cuid())
  commentId String
  url       String   @db.Text
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  comment   KanbanComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("kanban_comment_images")
}
